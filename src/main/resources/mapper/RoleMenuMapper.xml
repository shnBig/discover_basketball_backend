<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gain.mapper.RoleMenuMapper">

    <resultMap id="BaseResultMap" type="com.gain.domain.entity.RoleMenu">
        <id column="id" property="id"/>
        <result column="role_id" property="roleId"/>
        <result column="menu_id" property="menuId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.gain.domain.entity.RoleMenu" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO role_menu (role_id, menu_id, created_at)
        VALUES (#{roleId}, #{menuId}, #{createdAt})
    </insert>

    <delete id="deleteByRoleId">
        DELETE FROM role_menu WHERE role_id = #{roleId}
    </delete>

    <delete id="deleteByMenuId">
        DELETE FROM role_menu WHERE menu_id = #{menuId}
    </delete>

    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT * FROM role_menu WHERE role_id = #{roleId}
    </select>

    <select id="selectByMenuId" resultMap="BaseResultMap">
        SELECT * FROM role_menu WHERE menu_id = #{menuId}
    </select>

</mapper>
